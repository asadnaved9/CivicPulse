# ============================================================
# CivicPulse - Environment Variables Reference
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is gitignored for security.
# ============================================================

# ----- GEMINI / AI KEYS -----
# Required for Gemini AI API calls (server-side and client-side agents)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ----- APP CONFIG -----
# The deployed URL of this app (used for OAuth callbacks, self-referential links)
APP_URL="https://your-app.example.com"

# ----- FIREBASE CLIENT CONFIGURATION (REQUIRED FOR AUTH) -----
# All VITE_ prefixed vars are bundled into the frontend by Vite at build time.
# You MUST set these on your deployment platform (Vercel / Firebase Hosting / etc.)
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="1:YOUR_SENDER_ID:web:YOUR_APP_HASH"

# ----- GOOGLE MAPS -----
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
# Map ID from Google Cloud Console → Maps → Map Management (leave blank if not using styled maps)
VITE_GOOGLE_MAPS_MAP_ID="YOUR_MAP_ID_OR_LEAVE_BLANK"

# ----- ORCHESTRATOR -----
# Set to "true" to disable background agent loop in sandbox or local testing
DISABLE_ORCHESTRATOR="false"

# ----- FALLBACK AI PROVIDERS (optional) -----
# If Gemini fails, these providers are tried in order defined by FALLBACK_MODELS
GROQ_API_KEY="YOUR_GROQ_API_KEY"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
NVIDIA_NIM_API_KEY="YOUR_NVIDIA_NIM_API_KEY"
# Priority sequence: provider:model pairs, comma-separated
FALLBACK_MODELS="gemini:gemini-2.5-flash,gemini:gemini-2.0-flash-lite,groq:llama-3.3-70b-versatile,openrouter:google/gemini-2.5-flash,nvidia-nim:meta/llama3-70b-instruct"
